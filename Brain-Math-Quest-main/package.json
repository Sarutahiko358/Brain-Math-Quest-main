{
  "name": "rpgnoutore",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:eslint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "lint:watch": "eslint . --ext .ts,.tsx --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --config vitest.config.ci.ts --coverage=false",
    "test:fast": "vitest run --config vitest.config.ci.ts --coverage=false",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ui": "vitest run --coverage && open coverage/index.html"
  },
  "dependencies": {
    "next": "15.1.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.2",
    "jsdom": "^27.0.0",
    "sharp": "^0.34.4",
    "typescript": "^5.5.4",
    "vitest": "^3.2.4"
  }
}
